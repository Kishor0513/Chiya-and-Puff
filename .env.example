# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL (Neon) - get this from your Neon project dashboard
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ─── Authentication ──────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET="replace-this-with-a-strong-random-secret"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
